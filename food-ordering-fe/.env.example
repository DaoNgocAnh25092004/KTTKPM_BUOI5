# ==============================================================
# Frontend Environment Config — Máy chạy Frontend (máy khác)
# ==============================================================
# Sao chép file này thành .env rồi điền IP thật của máy backend
#
#   cp .env.example .env
#   (Sau đó Edit .env, thay 192.168.X.X bằng IP máy backend)
# ==============================================================

# IP của máy đang chạy Docker Compose (máy backend)
VITE_USER_SERVICE_URL=http://192.168.X.X:8081
VITE_FOOD_SERVICE_URL=http://192.168.X.X:8082
VITE_ORDER_SERVICE_URL=http://192.168.X.X:8083
VITE_PAYMENT_SERVICE_URL=http://192.168.X.X:8084
